{
  "functions": {
    "*.php": {
      "runtime": "vercel-php@0.7.1"
    },
    "admin/*.php": {
      "runtime": "vercel-php@0.7.1"
    },
    "user/*.php": {
      "runtime": "vercel-php@0.7.1"
    }
  },
  "routes": [
    {
      "src": "/admin/(.*)",
      "dest": "/admin/$1"
    },
    {
      "src": "/user/(.*)",
      "dest": "/user/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
